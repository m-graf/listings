<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ property.title }} | {{ property.location }} | {{ site.brand }}</title>
  <link rel="stylesheet" href="{{ css_href }}">
</head>
<body class="property-page">
{% macro executive_assistance_link(ea_name, brokers) -%}
{%- set ns = namespace(matched=false, idx=0) -%}
{%- for b in brokers -%}
{%- if not ns.matched and (b.name | trim) == (ea_name | trim) -%}
{%- set ns.matched = true -%}
{%- set ns.idx = loop.index0 -%}
{%- endif -%}
{%- endfor -%}
{%- if ns.matched -%}
<a class="executive-assistance__link" href="#broker-{{ ns.idx }}">{{ ea_name }}</a>
{%- else -%}
<span class="executive-assistance__name">{{ ea_name }}</span>
{%- endif -%}
{%- endmacro %}
  <a class="skip-link" href="#facts">Skip to content</a>

  <div class="hero">
    <div class="hero__image-wrap">
      <img
        class="hero__image"
        src="{{ property.hero_image.src }}"
        alt="{{ property.hero_image.alt }}"
        {% if property.hero_image.width and property.hero_image.height %}
        width="{{ property.hero_image.width }}"
        height="{{ property.hero_image.height }}"
        {% endif %}
        fetchpriority="high"
        decoding="async">
    </div>
    <div class="hero__content">
      <div class="hero__content-inner">
        <div class="hero__title hero__title--hide-mobile">
          <div class="page-title">
            <h1 class="page-title__header page-title__header--lower">{{ property.title }}</h1>
            <p class="page-title__subheader">{{ property.location }}</p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="inner">
    <article class="property">
      <div class="row">
        <header class="property-header">
          <h1 class="property-header__title">{{ property.title }}</h1>
          <p class="property-header__location">{{ property.location }}</p>
          <ul class="property-header__meta meta">
            {% if property.acres_label %}<li class="meta__acres">{{ property.acres_label }}</li>{% endif %}
            {% if property.price_label %}<li class="meta__price">{{ property.price_label }}</li>{% endif %}
            {% if property.status %}<li class="meta__status">{{ property.status }}</li>{% endif %}
          </ul>
        </header>
      </div>

      <nav class="property-nav property-nav--stuck" aria-label="Section navigation">
        <div class="row">
          <ul class="property-nav__items">
            <li><a class="property-nav__link" href="#facts">Overview &amp; Facts</a></li>
            {% if property.map_embed_url %}<li class="property-nav__maps"><a class="property-nav__link" href="#map">Interactive Map</a></li>{% endif %}
            {% if property.helpful_links and property.helpful_links|length > 0 %}<li><a class="property-nav__link" href="#helpful-links">Helpful links</a></li>{% endif %}
            {% if property.downloads and property.downloads|length > 0 %}<li class="property-nav__downloads"><a class="property-nav__link" href="#downloads">Maps &amp; Downloads</a></li>{% endif %}
            {% if property.detail_tabs and property.detail_tabs|length > 0 %}<li><a class="property-nav__link" href="#details">Property Details</a></li>{% endif %}
          </ul>
        </div>
      </nav>

      <div class="row">
        {% set has_sidebar = (property.brokers and property.brokers|length > 0) or (property.executive_assistance and property.executive_assistance|length > 0) %}
        <div class="property-intro{% if property.brokers and property.brokers|length > 1 %} property-intro--two-brokers{% endif %}">
          {% if has_sidebar %}
          <div class="property-intro__sidebar">
          {% if property.brokers and property.brokers|length > 0 %}
          <div class="property-intro__brokers{% if property.brokers|length > 1 %} property-intro__brokers--multiple{% endif %}">
            {% for b in property.brokers %}
            <aside class="broker-card" id="broker-{{ loop.index0 }}">
              <div class="broker-card__image">
                <img src="{{ b.photo | gallery_img_src }}" alt="{{ b.name }}" width="320" height="400" loading="lazy" decoding="async"{% if b.photo_object_position %} style="object-position: {{ b.photo_object_position | e }}"{% endif %}>
              </div>
              <div class="broker-card__content">
                <h3 class="broker-card__name">{{ b.name }}</h3>
                <p class="broker-card__title">{{ b.title }}</p>
                {% if b.about_url %}<p class="broker-card__item"><a href="{{ b.about_url }}">{{ b.about_label | default('About') }}</a></p>{% endif %}
                {% if b.phone %}<p class="broker-card__item">(Cell) {{ b.phone }}</p>{% endif %}
                <div class="broker-card__actions">
                  {% if b.phone_tel %}
                  <div class="broker-card__actions-row">
                    <a class="button button--small broker-card__actions-btn" href="tel:{{ b.phone_tel }}">Call</a>
                  </div>
                  <div class="broker-card__actions-row">
                    <a class="button button--small broker-card__actions-btn" href="sms:{{ b.phone_tel }}">Text</a>
                  </div>
                  {% endif %}
                  {% if b.email %}
                  <div class="broker-card__actions-row">
                    <a class="button button--small button--brown broker-card__actions-btn" href="{{ b.email | listing_inquiry_mailto(property) }}">Email</a>
                  </div>
                  {% endif %}
                </div>
              </div>
            </aside>
            {% endfor %}
          </div>
          {% endif %}
          {% if property.executive_assistance and property.executive_assistance|length > 0 %}
          <section class="executive-assistance" aria-label="Executive assistance">
            <h3 class="executive-assistance__title">Executive assistance</h3>
            <ul class="executive-assistance__list">
              {% for ea in property.executive_assistance %}
              <li class="executive-assistance__item">
                {% if ea.name is defined and ea.name %}
                <div class="executive-assistance__entry">
                  <span class="executive-assistance__line">
                    {{ executive_assistance_link(ea.name, property.brokers or []) }}
                    {% if ea.title %}<span class="executive-assistance__role"> — {{ ea.title }}</span>{% endif %}
                  </span>
                  {% if ea.phone or ea.email %}
                  <span class="executive-assistance__contact">
                    {% if ea.phone %}
                    <span class="executive-assistance__contact-row">
                      {% if ea.phone_tel %}<a class="executive-assistance__contact-link" href="tel:{{ ea.phone_tel }}">{{ ea.phone }}</a>{% else %}<span>{{ ea.phone }}</span>{% endif %}
                    </span>
                    {% endif %}
                    {% if ea.email %}
                    <span class="executive-assistance__contact-row">
                      <a class="executive-assistance__contact-link" href="{{ ea.email | listing_inquiry_mailto(property) }}">{{ ea.email }}</a>
                    </span>
                    {% endif %}
                  </span>
                  {% endif %}
                </div>
                {% else %}
                {{ executive_assistance_link(ea, property.brokers or []) }}
                {% endif %}
              </li>
              {% endfor %}
            </ul>
          </section>
          {% endif %}
          </div>
          {% endif %}
          {% if property.intro_html %}
          <div class="property-intro__copy wysiwyg-pdc">
            {{ property.intro_html | safe }}
          </div>
          {% elif property.intro_paragraphs %}
          <div class="property-intro__copy wysiwyg-pdc">
            {% for p in property.intro_paragraphs %}
            <p>{{ p }}</p>
            {% endfor %}
          </div>
          {% endif %}
        </div>
      </div>

      {% if (property.gallery_images and property.gallery_images|length > 0) or property.gallery_drive_url %}
      <div class="row">
        <section class="property-overview-gallery" aria-labelledby="gallery-heading">
          <h2 id="gallery-heading" class="section-title property-overview-gallery__title">Full Photo Gallery</h2>
          {% if property.gallery_drive_url %}
          <p class="gallery-drive-cta">
            <a class="button gallery-drive-cta__link" href="{{ property.gallery_drive_url }}" target="_blank" rel="noopener noreferrer">Open gallery on Google Drive</a>
          </p>
          {% endif %}
          {% if property.gallery_images and property.gallery_images|length > 0 %}
          <div class="gallery-grid">
            {% for img in property.gallery_images %}
            {% set g_src = (img.src or '') | trim %}
            {% set g_href = img.src | gallery_link_href %}
            {% if (g_src | lower)[-4:] == '.pdf' %}
            {% set g_thumb = (img.thumb or '') | trim %}
            <a class="gallery-grid__cell gallery-grid__cell--pdf{% if g_thumb %} gallery-grid__cell--pdf-thumb{% endif %}" href="{{ g_href }}" target="_blank" rel="noopener noreferrer">
              {% if g_thumb %}
              <img src="{{ g_thumb | gallery_img_src }}" alt="{{ img.alt | default('PDF document', true) }}" loading="lazy" decoding="async">
              <span class="gallery-grid__pdf-ribbon" aria-hidden="true">PDF</span>
              {% else %}
              <span class="gallery-grid__pdf-card">
                <span class="gallery-grid__pdf-badge">PDF</span>
                <span class="gallery-grid__pdf-caption">{{ img.alt | default('Open PDF', true) }}</span>
              </span>
              {% endif %}
            </a>
            {% else %}
            <a class="gallery-grid__cell" href="{{ g_href }}" target="_blank" rel="noopener noreferrer">
              <img src="{{ g_src | gallery_img_src }}" alt="{{ img.alt | default('') }}" loading="lazy" decoding="async">
            </a>
            {% endif %}
            {% endfor %}
          </div>
          {% endif %}
        </section>
      </div>
      {% endif %}

      {% if property.brokers_comment_html %}
      <div class="row">
        <section class="property-comments wysiwyg-pdc">
          <h3>Broker’s Comment</h3>
          <div class="property-comments__body">{{ property.brokers_comment_html | safe }}</div>
        </section>
      </div>
      {% elif property.brokers_comment %}
      <div class="row">
        <section class="property-comments wysiwyg-pdc">
          <h3>Broker’s Comment</h3>
          <p><em>“{{ property.brokers_comment }}”</em></p>
        </section>
      </div>
      {% endif %}

      <div class="property-facts" id="facts">
        <div class="row">
          <h2 class="section-title">Overview &amp; Facts</h2>
          <ul class="property-facts__list">
            {% for fact in property.facts %}
            <li class="property-facts__item">{{ fact }}</li>
            {% endfor %}
          </ul>
        </div>
      </div>

      {% if property.map_embed_url %}
      <div class="row">
        <div class="property-map" id="map">
          <h2 class="section-title">Interactive Map</h2>
          <div class="property-map__embed">
            <iframe title="Property map" src="{{ property.map_embed_url }}" loading="lazy"></iframe>
          </div>
        </div>
      </div>
      {% endif %}

      {% if property.helpful_links and property.helpful_links|length > 0 %}
      <div class="row">
        <section class="helpful-links" id="helpful-links" aria-labelledby="helpful-links-heading">
          <h2 id="helpful-links-heading" class="section-title">Helpful links</h2>
          <ul class="helpful-links__list">
            {% for link in property.helpful_links %}
            {% set hl_heading = link.title | default(link.label | default('Link')) %}
            {% set hl_action = link.link_text | default('Open in browser') %}
            <li class="helpful-links__item">
              <div class="helpful-links__card">
                {% if link.qr_src %}
                <a class="helpful-links__qr-wrap" href="{{ link.href }}" target="_blank" rel="noopener noreferrer" aria-label="{{ hl_heading }} — {{ hl_action }}">
                  <img class="helpful-links__qr" src="{{ link.qr_src }}" alt="QR code: {{ hl_heading }}" width="176" height="176" loading="lazy" decoding="async">
                </a>
                {% endif %}
                <div class="helpful-links__body">
                  <h3 class="helpful-links__title">{{ hl_heading }}</h3>
                  {% if link.description %}
                  <p class="helpful-links__description">{{ link.description }}</p>
                  {% endif %}
                  <p class="helpful-links__action">
                    <a class="helpful-links__link" href="{{ link.href }}" target="_blank" rel="noopener noreferrer">{{ hl_action }}</a>
                  </p>
                </div>
              </div>
            </li>
            {% endfor %}
          </ul>
        </section>
      </div>
      {% endif %}

      {% if property.downloads and property.downloads|length > 0 %}
      <div class="row">
        <div class="property-downloads" id="downloads">
          <h2 class="section-title">Maps &amp; Downloads</h2>
          <ul class="property-downloads__list">
            {% for d in property.downloads %}
            <li>
              <a class="download" href="{{ d.href }}" target="_blank" rel="noopener noreferrer">
                {% if d.thumb %}
                <div class="download__image-wrap">
                  <img class="download__image" src="{{ d.thumb | gallery_img_src }}" alt="{{ d.thumb_alt | default('') }}" width="500" height="386" loading="lazy">
                </div>
                {% endif %}
                <h3 class="download__title">{{ d.title }}</h3>
                <span class="download__button button">{{ d.action_label | default('Download') }}</span>
              </a>
            </li>
            {% endfor %}
          </ul>
        </div>
      </div>
      {% endif %}

      {% if property.detail_tabs and property.detail_tabs|length > 0 %}
      <div class="row">
        <div class="tabbed-details" id="details">
          <h2 class="section-title">Property Details</h2>
          {% for tab in property.detail_tabs %}
          <details class="tabbed-details__block" {% if loop.first %}open{% endif %}>
            <summary class="tabbed-details__summary">{{ tab.label }}</summary>
            <div class="tabbed-details__body">
              {% if tab.paragraphs %}
                {% for p in tab.paragraphs %}<p>{{ p }}</p>{% endfor %}
              {% endif %}
              {% if tab.images and tab.images|length > 0 %}
              <div class="tabbed-details__gallery">
                {% for im in tab.images %}
                <a href="{{ im.src }}" target="_blank" rel="noopener noreferrer" class="tabbed-details__gallery-link">
                  <img src="{{ im.src }}" alt="{{ im.alt | default('') }}" loading="lazy">
                </a>
                {% endfor %}
              </div>
              {% endif %}
            </div>
          </details>
          {% endfor %}
        </div>
      </div>
      {% endif %}
    </article>
  </div>

  <footer class="site-footer">
    <div class="row">
      <p><a href="{{ site.home_url }}" rel="noopener noreferrer">{{ site.footer_label | default(site.brand) }}</a></p>
    </div>
  </footer>
  {% include '_analytics.html.j2' %}
</body>
</html>
