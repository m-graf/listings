{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/property.schema.json",
  "title": "Property listing",
  "type": "object",
  "required": ["slug", "title", "location", "hero_image", "intro_paragraphs", "facts"],
  "properties": {
    "slug": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "title": { "type": "string" },
    "location": { "type": "string" },
    "acres_label": { "type": "string" },
    "price_label": { "type": "string" },
    "status": { "type": "string" },
    "hero_image": {
      "type": "object",
      "required": ["src", "alt"],
      "properties": {
        "src": { "type": "string", "format": "uri" },
        "alt": { "type": "string" },
        "width": { "type": "integer" },
        "height": { "type": "integer" }
      }
    },
    "intro_paragraphs": { "type": "array", "items": { "type": "string" } },
    "brokers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "title", "photo"],
        "properties": {
          "name": { "type": "string" },
          "title": { "type": "string" },
          "photo": { "type": "string" },
          "about_url": { "type": "string" },
          "about_label": { "type": "string" },
          "phone": { "type": "string" },
          "phone_tel": { "type": "string" },
          "email": { "type": "string", "format": "email" }
        }
      }
    },
    "brokers_comment": { "type": ["string", "null"] },
    "executive_assistance": {
      "type": "array",
      "description": "Plain string (name; link if matches a broker) or object with contact fields",
      "items": {
        "oneOf": [
          { "type": "string" },
          {
            "type": "object",
            "required": ["name"],
            "properties": {
              "name": { "type": "string" },
              "title": { "type": "string" },
              "email": { "type": "string" },
              "phone": { "type": "string" },
              "phone_tel": { "type": "string" }
            },
            "additionalProperties": false
          }
        ]
      }
    },
    "gallery_drive_url": {
      "type": ["string", "null"],
      "description": "Shared Google Drive folder or gallery link; shows Open gallery on Google Drive"
    },
    "gallery_images": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["src"],
        "properties": {
          "src": {
            "type": "string",
            "description": "Image URL or Google Drive file share link (Anyone with link can view)"
          },
          "alt": { "type": "string" }
        }
      }
    },
    "facts": { "type": "array", "items": { "type": "string" } },
    "map_embed_url": { "type": ["string", "null"] },
    "helpful_links": {
      "type": "array",
      "description": "External links with optional title, description, link_text; build adds QR SVGs under static/qr/",
      "items": {
        "type": "object",
        "required": ["href"],
        "properties": {
          "href": { "type": "string" },
          "title": { "type": "string", "description": "Card heading" },
          "description": { "type": "string", "description": "Short paragraph under the title" },
          "link_text": { "type": "string", "description": "Text for the text link (default: Open in browser)" },
          "label": { "type": "string", "description": "Legacy: used as heading if title omitted" }
        }
      }
    },
    "downloads": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["title", "href"],
        "properties": {
          "title": { "type": "string" },
          "href": { "type": "string" },
          "thumb": { "type": "string" },
          "thumb_alt": { "type": "string" },
          "action_label": { "type": "string", "description": "Button label (default: Download)" }
        }
      }
    },
    "detail_tabs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["label"],
        "properties": {
          "label": { "type": "string" },
          "paragraphs": { "type": "array", "items": { "type": "string" } },
          "images": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["src"],
              "properties": {
                "src": { "type": "string" },
                "alt": { "type": "string" }
              }
            }
          }
        }
      }
    }
  }
}
